{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    {
      "identifier": "shell:allow-open",
      "allow": [
        {
          "url": "https://github.com/*"
        }
      ]
    }
  ]
}
