{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hangman Game (by Mayuk)",
  "version": "2.3.1",
  "identifier": "com.hangman.game",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hangman",
        "width": 1200,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU5NkRDQzkyQTQ4M0YzMDEKUldRQjg0T2trc3h0V2FuWWdacGc0NEx4ZWVLTjZoV2RETEFIWUpoTG1NZ1U3cUY2SXBnNUlkdmwK",
      "endpoints": [
        "https://github.com/MayukXT/hangman/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "basicUi"
      }
    }
  }
}
